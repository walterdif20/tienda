rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);

      match /images/{imageId} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
      }
    }

    match /inventory/{productId} {
      allow read: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
      allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId)
        || (request.query.token != null && request.query.token == resource.data.publicTrackingToken)
        || (request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true));
      allow update: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);

      match /items/{itemId} {
        allow read: if (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.userId)
          || (request.query.token != null && request.query.token == get(/databases/$(database)/documents/orders/$(orderId)).data.publicTrackingToken)
          || (request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true));
        allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
      }
    }

    match /storeSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || request.auth.token.role == 'admin' || request.auth.token.isAdmin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
