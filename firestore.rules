rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminFromUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        );
    }

    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true;
      allow write: if isAdminFromUserDoc();
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true;
      allow write: if isAdminFromUserDoc();

      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdminFromUserDoc();
      }
    }

    match /inventory/{productId} {
      allow read: if isAdminFromUserDoc();
      allow write: if isAdminFromUserDoc();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId)
        || (request.query.token != null && request.query.token == resource.data.publicTrackingToken)
        || isAdminFromUserDoc();
      allow update: if isAdminFromUserDoc()
        || (
          request.resource.data.publicTrackingToken == resource.data.publicTrackingToken
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.buyer == resource.data.buyer
          && request.resource.data.delivery == resource.data.delivery
          && request.resource.data.total == resource.data.total
          && request.resource.data.subtotal == resource.data.subtotal
          && request.resource.data.shippingCost == resource.data.shippingCost
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.stockDiscounted == resource.data.stockDiscounted
          && request.resource.data.status == 'paid'
          && resource.data.status == 'pending'
          && request.resource.data.payment.provider == resource.data.payment.provider
          && request.resource.data.payment.transferAlias == resource.data.payment.transferAlias
        );

      match /items/{itemId} {
        allow read: if (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.userId)
          || (request.query.token != null && request.query.token == get(/databases/$(database)/documents/orders/$(orderId)).data.publicTrackingToken)
          || isAdminFromUserDoc();
        allow create: if true;
        allow update, delete: if isAdminFromUserDoc();
      }
    }

    match /storeSettings/{docId} {
      allow read: if true;
      allow write: if isAdminFromUserDoc();
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdminFromUserDoc());

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['role', 'isAdmin']);

      allow update: if isSignedIn() && (
        isAdminFromUserDoc()
        || (
          request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.isAdmin == resource.data.isAdmin
        )
      );

      allow delete: if false;
    }
  }
}
